!screenshots/Shops/*/Icon.png
!screenshots/Shops/*/icon.png
!screenshots/Shops/*/1-8.png
!screenshots/Shops/*/9.png

# Local dev files
start.bat
capture_tool.py
*.pyc
__pycache__/
.claude/
